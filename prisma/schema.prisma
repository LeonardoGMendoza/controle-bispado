generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model NotaFiscal {
  id          Int      @id @default(autoincrement())
  fornecedor  String
  cnpj        String?
  valor       Float
  dataEmissao DateTime
  categoria   String?
  descricao   String?
  status      String   @default("Pendente")
  urlAnexo    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Missao {
  id          Int       @id @default(autoincrement())
  missionario String
  destino     String
  dataPartida DateTime?
  dataRetorno DateTime?
  status      String    @default("Ativo")
  observacoes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// NOVA TABELA: O Cérebro do "Secretário Inteligente"
model Jovem {
  id                     Int       @id @default(autoincrement())
  nome                   String
  telefone               String?
  organizacao            String    // "Rapazes" ou "Moças"
  classeOuQuorum         String?   // "Diáconos", "Guardiãs da Luz", etc.
  cargo                  String?   // Ex: "Presidente", "Consultor", "VAGO"
  dataNascimento         DateTime?
  dataUltimaEntrevista   DateTime?
  faltouUltimoDomingo    Boolean   @default(false)
  faltouPenultimoDomingo Boolean   @default(false)
  faltouAtividade        Boolean   @default(false)
  status                 String    @default("Ativo")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}